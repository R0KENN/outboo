# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Режим БД: sqlite или postgres
DB_DRIVER=sqlite

# Для SQLite используется этот путь
SQLITE_PATH=bot.db

# Для PostgreSQL (если DB_DRIVER=postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=botuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=botdb

# Логирование
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# Антифлуд по умолчанию (можно переопределять per-chat в БД)
THROTTLE_RATE=0.7

# id владельцев бота через запятую (для команд постинга в личке с ботом)
BOT_ADMINS=123456789

# Google Sheets (раздел 4.6, опционально)
# Путь к JSON-ключу сервисного аккаунта Google
GOOGLE_CREDS_PATH=google_creds.json
# ID таблицы (из её URL: docs.google.com/spreadsheets/d/<ЭТО_ID>/edit)
GOOGLE_SHEET_ID=
